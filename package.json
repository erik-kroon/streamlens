{
  "name": "wiretap",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:agent": "cd apps/agent && go run ./cmd/wiretap-agent",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@wiretap/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "@wiretap/config": "workspace:*",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
